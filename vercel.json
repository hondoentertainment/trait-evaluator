{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/crosswalk", "destination": "/crosswalk.html" }
  ],
  "functions": {
    "api/evaluate.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
