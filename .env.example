# --- AI (pick one path) ---
# 1) Prefer Vercel AI Gateway — after `vercel link` + `vercel env pull .env.local`
#    you get VERCEL_OIDC_TOKEN automatically on Vercel; Gateway routes to Grok.
# 2) Or paste an xAI key from https://console.x.ai/
XAI_API_KEY=
# AI_GATEWAY_API_KEY=

# --- GitHub-backed sync + short shares + eval cache ---
DATA_REPO=hondoentertainment/profileread-data
# Prefer a fine-grained PAT with contents:write on DATA_REPO only.
# Rotate if this was ever a classic personal token pasted into chat/CI:
#   GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=

# --- Optional Clerk (https://dashboard.clerk.com or Vercel Marketplace) ---
# When set, home shows Sign in and links the recovery account to Clerk user id.
CLERK_PUBLISHABLE_KEY=

# --- Admin telemetry (/admin + /api/admin) ---
ADMIN_SECRET=

# --- Optional Blob (scripts/fix-blob.mjs experiments only) ---
# BLOB_READ_WRITE_TOKEN=
# BLOB_STORE_ID=
